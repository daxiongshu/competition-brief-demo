617:     t2=kna.tail(20); dvt2=np.diff(t2['TVT_input'].values);                     \n627:                    gg,gs2,gmin,gst,gs,float(kna['TVT_input'].iloc[-1]),iv,     \n636: _pf_ancc(_md,_z,_gr,_gg,45.,0.1,20.,50.,0.,8,0.998,0.002,0.005,0.3,0.1,0.001,0 \n668: def multi_scale_ncc(kgr,ktvt,hgr,hws=(8,15,25),stride=3):                      \n690:         ncc=Hn@Cn.T/win; best=ncc.argmax(1); score=ncc.max(1).astype(np.float3 \n749:         xs,ys,anccs,wids=[],[],[],[]                                           \n758:             anccs.append(s['ANCC'].values); wids.extend([wid]*len(s))          \n760:         self.ancc=np.concatenate(anccs).astype(np.float32);                    \n767: nf=min(nfetch,len(self.ancc))                                                  \n773:         sw=w.sum(1); safe=np.where(sw<1e-9,1.,sw); an=self.ancc[ik]            \n774:         ap=(an*w).sum(1)/safe; ap=np.where(sw<1e-9,float(self.ancc.mean()),ap) \n798:     kn=hw[hw['TVT_input'].notna()]; ev=hw[hw['TVT_input'].isna()]              \n804:     pf_a,std_a=run_pf_ancc(hw,tw_tvt,tw_gr)                                    \n810:     lk=kn.iloc[-1]; last_tvt=float(lk['TVT_input'])                            \n823:     ktvt=kn['TVT_input'].to_numpy(np.float32)                                  \n824:     sc_res,sc_ens=multi_scale_ncc(kgr,ktvt,hgr,hws=(8,15,25),stride=3)         \n827:     sc_trust=float(np.clip(len(kn)/200.,0.,0.6))                               \n828:     hyb_ref=(1-sc_trust)*beam_ref+sc_trust*sc_ens  # use ensemble not single   \n\\n### read_sunnywu27__rogii-wellbore-tvt-physical-model.md\n1:Reading kernel: sunnywu27/rogii-wellbore-tvt-physical-model\n10:   - Visible training wells: physical model (RMSE ~0.007 ft)                    \n12:     init_spread=2.0 ft (wider initial particle spread)                         \n66: def run_particle_filter(hw, tw, n_particles=500, seed=42):                     \n72:     kn = hw[hw['TVT_input'].notna()]                                           \n73:     ev = hw[hw['TVT_input'].isna()]                                            \n75:         return hw['TVT_input'].values.astype(float).copy(), 0.0                \n78:     last_tvt = float(last['TVT_input'])                                        \n82:     tw_at_k = np.interp(kn['TVT_input'].values, tw_tvt, tw_gr)                 \n87:     dt = np.diff(tail['TVT_input'].values)                                     \n93:     N   = n_particles                                                          \n111:     out_vals = hw['TVT_input'].values.astype(float).copy()                     \n150: def run_pf_lik_ensemble(hw, tw, n_particles=500, n_seeds=128, scale=5.0):      \n158:         p, ll = run_particle_filter(hw, tw, n_particles=n_particles, seed=s)   \n258:     kn = hw[hw['TVT_input'].notna()]                                           \n259:     ev = hw[hw['TVT_input'].isna()]                                            \n261:         return hw['TVT_input'].values.astype(float).copy()                     \n263:     last_tvt = float(kn.iloc[-1]['TVT_input'])                                 \n278:     out = hw['TVT_input'].values.astype(float).copy()                          \n306:             hw_te['TVT_input'] = hw_tr['TVT_input'].values                     \n316:         tvt_pf = run_pf_lik_ensemble(hw_te, tw_ref, n_particles=500,           \n321:         last_known = hw_te['TVT_input'].dropna()                               \n323:         tvt_pf = hw_te['TVT_input'].fillna(last_val).values.astype(float)      \n338:             # Visible well: physical model is primary (RMSE ~0.007 ft)         \n","exit_code":0,"status":"completed"}}
