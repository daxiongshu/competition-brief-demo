{"type":"item.started","item":{"id":"item_37","type":"command_execution","command":"/bin/bash -lc \"cat > /tmp/make_rogii_plots.py <<'PY'\nimport json, re, pathlib, textwrap\nimport pandas as pd\nimport numpy as np\nimport matplotlib.pyplot as plt\n\nrun = pathlib.Path('/nvidia-kaggle/demo/competition-intel-briefing/runs/codex_rogii-wellbore-geology-prediction_002')\nwork = run/'work'\nplots = run/'plots'\nplots.mkdir(parents=True, exist_ok=True)\n\nplt.style.use('seaborn-v0_8-whitegrid')\n\n# Plot 1: public notebook score claims extracted from titles\nkernels = json.loads((work/'kernels_top80.json').read_text())\nscore_rows=[]\nfor k in kernels:\n    title=k['title']\n    # LB title claims only; avoid CV-only titles\n    m_lb = re.search(r'\\\\bLB\\\\s*[:\\\\- ]*([0-9]+(?:\\\\.[0-9]+)?)', title, re.I)\n    m_prefix = re.match(r'\\\\s*([0-9]+\\\\.[0-9]+)\\\\s+ROGII', title, re.I)\n    if m_lb:\n        score=float(m_lb.group(1)); kind='LB title claim'\n    elif m_prefix and 'dwt' in title.lower():\n        score=float(m_prefix.group(1)); kind='title score claim'\n    else:\n        continue\n    score_rows.append({**k,'score':score,'kind':kind,'label':title[:45]})\nscore_df=pd.DataFrame(score_rows).sort_values('score')\nscore_df.to_csv(work/'title_score_claims.csv', index=False)\nif len(score_df):\n    fig, ax = plt.subplots(figsize=(9, max(4, 0.45*len(score_df)+1)))\n    colors = ['#4C78A8' if 'LB' in k else '#F58518' for k in score_df['kind']]\n    ax.barh(score_df['label'], score_df['score'], color=colors)\n    ax.set_xlabel('RMSE claimed in notebook title (lower is better)')\n    ax.set_title('Public notebook title-claimed scores (not independently verified)')\n    ax.invert_yaxis()\n    for y, v in enumerate(score_df['score']): ax.text(v+0.05, y, f'{v:.3f}', va='center', fontsize=8)\n    fig.tight_layout(); fig.savefig(plots/'public_notebook_score_claims.png', dpi=180); plt.close(fig)\n\n# Plot 2: public notebook engagement top 15\neng=pd.DataFrame(kernels[:15])\nfig, ax=plt.subplots(figsize=(9,6))\nlabels=[t[:42] for t in eng['title']]\nax.barh(labels, eng['total_votes'], color='#54A24B')\nax.set_xlabel('Kaggle votes')\nax.set_title('Most-voted public notebooks (engagement, not rank)')\nax.invert_yaxis()\nfig.tight_layout(); fig.savefig(plots/'top_public_notebooks_votes.png', dpi=180); plt.close(fig)\n\n# Plot 3: sample wells eval-zone geometry and known fraction\ndata_dir=work/'data_probe'\nwell_rows=[]\nfig, axes=plt.subplots(2,2,figsize=(12,7), sharex=False, sharey=False)\nfor ax, hw_path in zip(axes.ravel(), sorted(data_dir.glob('*__horizontal_well.csv'))[:4]):\n    well=hw_path.name.split('__')[0]\n    hw=pd.read_csv(hw_path)\n    known=hw['TVT_input'].notna()\n    eval_mask=~known\n    well_rows.append({\n        'well':well,'rows':len(hw),'known_rows':int(known.sum()),'eval_rows':int(eval_mask.sum()),\n        'known_fraction':float(known.mean()),'gr_nonnull_fraction':float(hw['GR'].notna().mean()),\n        'tvt_range':float(hw['TVT'].max()-hw['TVT'].min()) if 'TVT' in hw else np.nan,\n    })\n    ax.plot(hw['MD'], hw['TVT'], color='#4C78A8', lw=1.2, label='true TVT')\n    ax.scatter(hw.loc[known,'MD'], hw.loc[known,'TVT_input'], s=2, color='#54A24B', label='visible TVT_input')\n    if eval_mask.any():\n        ax.axvspan(hw.loc[eval_mask,'MD'].min(), hw.loc[eval_mask,'MD'].max(), color='#F58518', alpha=0.16, label='evaluation zone')\n    ax.set_title(f'Well {well}: known {known.mean():.0%}, GR present {hw.GR.notna().mean():.0%}')\n    ax.set_xlabel('Measured Depth (MD)')\n    ax.set_ylabel('TVT')\nhandles, labels0 = axes[0,0].get_legend_handles_labels()\nfig.legend(handles, labels0, loc='upper center', ncol=3, frameon=False)\nfig.suptitle('Downloaded example wells: predict after visible TVT_input ends', y=1.02)\nfig.tight_layout(); fig.savefig(plots/'example_well_tvt_input_windows.png', dpi=180, bbox_inches='tight'); plt.close(fig)\npd.DataFrame(well_rows).to_csv(work/'example_well_summary.csv', index=False)\n\n